# IvyDB ClickHouse connection settings.
#
# Copy this file to ivydb/.env on the machine that runs the loader, then edit
# the values. Do not commit ivydb/.env because it contains a password.

# ClickHouse host name or Docker-published host address.
IVYDB_CLICKHOUSE_HOST=localhost

# ClickHouse HTTP interface port.
IVYDB_CLICKHOUSE_PORT=8123

# ClickHouse user defined in ivydb.xml.
IVYDB_CLICKHOUSE_USERNAME=ivydb_user

# ClickHouse password matching the user XML or SQL-managed user.
IVYDB_CLICKHOUSE_PASSWORD=replace-me

# Set true only when using HTTPS/TLS for the ClickHouse HTTP interface.
IVYDB_CLICKHOUSE_SECURE=false

# Target database for IvyDB tables.
IVYDB_CLICKHOUSE_DATABASE=ivydb
